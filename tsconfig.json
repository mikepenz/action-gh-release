{
  "compilerOptions": {
    "useUnknownInCatchVariables": false,
    "target": "es2022",
    "module": "NodeNext",
    "outDir": "./lib",
    "rootDir": "./src",
    "strict": true,
    "noImplicitAny": false,
    "skipLibCheck": true,
    "types": ["vitest/globals"],
    "esModuleInterop": true
  },
  "exclude": ["node_modules", "**/*.test.ts", "vitest.config.ts"]
}